{
  "name": "ctrlc",
  "version": "0.1.11",
  "description": "Cross-platform clipboard manager with hotkey-triggered popup",
  "main": "dist/main/main.js",
  "build": {
    "appId": "dev.seriousgeese.ctrlc",
    "productName": "CtrlC",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "linux": {
      "icon": "build-res/icon.png",
      "category": "Utility",
      "executableName": "ctrlc",
      "target": [
        "AppImage",
        "deb"
      ],
      "desktop": {
        "entry": {
          "StartupWMClass": "ctrlc"
        }
      }
    },
    "win": {
      "icon": "build-res/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "build-res/icon.png",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  },
  "author": "Serious Geese, LLC <https://seriousgeese.dev>",
  "license": "MIT",
  "scripts": {
    "start": "npm run build && bash -c 'exec -a CtrlC electron .'",
    "dev": "npm run build && bash -c 'exec -a CtrlC electron .'",
    "build": "tsc && cp src/renderer/*.html dist/renderer/",
    "build:app": "electron-builder",
    "build:linux": "npm run build && electron-builder --linux",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript-eslint/typescript-estree": "^8.62.0",
    "@vitest/browser": "^4.1.9",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
